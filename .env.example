# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram user ID (only this user can interact with the bot)
# Send /start to @userinfobot on Telegram to get your ID
ALLOWED_USER_ID=your-telegram-user-id

# Claude Code binary path (usually just "claude")
CLAUDE_BIN=claude

# Permission mode for non-interactive claude invocations
# Options: default, acceptEdits, bypassPermissions
CLAUDE_PERMISSION_MODE=bypassPermissions
